{
  "name": "mcp-landing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:css": "mkdir -p dist && tailwindcss -i ./src/input.css -o ./dist/out.css --minify",
    "build:html": "tsx build.ts",
    "build": "pnpm run build:css && pnpm run build:html",
    "preview": "pnpm run build && npx --yes serve dist -l 4173"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-ton-tech/mcp-landing.git"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
