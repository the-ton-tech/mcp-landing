{
  "name": "mcp-landing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:css": "mkdir -p dist && tailwindcss -i ./src/input.css -o ./dist/out.css --minify",
    "build:html": "tsx build.ts",
    "build": "pnpm run build:css && pnpm run build:html",
    "watch:css": "mkdir -p dist && tailwindcss -i ./src/input.css -o ./dist/out.css --watch",
    "watch:html": "WATCH=1 tsx watch --include ./dist/out.css build.ts",
    "watch:serve": "browser-sync start --server dist --files 'dist/index.html' --no-notify --no-ui --port 4173 --reload-debounce 200",
    "watch": "pnpm run build && concurrently -n css,html,serve -c blue,green,magenta -k \"pnpm run watch:css\" \"pnpm run watch:html\" \"pnpm run watch:serve\"",
    "preview": "pnpm run build && npx --yes serve dist -l 4173"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-ton-tech/mcp-landing.git"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b"
}
